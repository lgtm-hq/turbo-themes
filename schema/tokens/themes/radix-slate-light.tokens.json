      "successText": {
        "$value": "#1c2024",
        "$type": "color"
      },
      "warningText": {
        "$value": "#1c2024",
        "$type": "color"
      },
      "dangerText": {
        "$value": "#121212",
        "$type": "color"
      }
    },
    "border": {
      "default": {
        "$value": "#d9d9e0",
        "$type": "color"
      }
    },
    "accent": {
      "link": {
        "$value": "#0c6fc6",
        "$type": "color"
      }
