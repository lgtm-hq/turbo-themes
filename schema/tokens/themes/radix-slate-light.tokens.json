{
  "$schema": "../../turbo-themes.schema.json#/$defs/ThemeFile",
  "id": "radix-slate-light",
  "label": "Radix Colors Slate Light",
  "vendor": "radix",
  "appearance": "light",
  "description": "Neutral blue-gray Radix light theme for accessible UIs.",
  "icon": "radix-slate-light.png",
  "tokens": {
    "background": {
      "base": {
        "$value": "#fcfcfd",
        "$type": "color"
      },
      "surface": {
