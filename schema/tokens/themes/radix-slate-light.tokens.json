      },
      "overlay": {
        "$value": "#f0f0f3",
        "$type": "color"
      }
    },
    "text": {
      "primary": {
        "$value": "#1c2024",
        "$type": "color"
      },
      "secondary": {
        "$value": "#60646c",
        "$type": "color"
      },
      "inverse": {
        "$value": "#fcfcfd",
        "$type": "color"
      }
    },
    "brand": {
      "primary": {
        "$value": "#0090ff",
        "$type": "color"
      },
      "primaryText": {
        "$value": "#232323",
        "$type": "color"
      }
