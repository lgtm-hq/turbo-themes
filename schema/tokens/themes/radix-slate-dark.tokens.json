{
  "$schema": "../../turbo-themes.schema.json#/$defs/ThemeFile",
  "id": "radix-slate-dark",
  "label": "Radix Colors Slate Dark",
  "vendor": "radix",
  "appearance": "dark",
  "description": "Neutral blue-gray Radix dark theme for accessible UIs.",
  "icon": "radix-slate-dark.png",
  "tokens": {
    "background": {
      "base": {
        "$value": "#111113",
        "$type": "color"
      },
      "surface": {
        "$value": "#18191b",
        "$type": "color"
      },
      "overlay": {
        "$value": "#212225",
        "$type": "color"
      }
    },
    "text": {
      "primary": {
        "$value": "#edeef0",
        "$type": "color"
      },
      "secondary": {
        "$value": "#b0b4ba",
        "$type": "color"
      },
      "inverse": {
        "$value": "#111113",
        "$type": "color"
      }
    },
    "brand": {
      "primary": {
        "$value": "#0090ff",
        "$type": "color"
      }
    },
    "state": {
      "info": {
        "$value": "#00a2c7",
        "$type": "color"
      },
      "success": {
        "$value": "#30a46c",
        "$type": "color"
      },
      "warning": {
        "$value": "#ffc53d",
        "$type": "color"
      },
      "danger": {
        "$value": "#e5484d",
        "$type": "color"
      }
    },
    "border": {
