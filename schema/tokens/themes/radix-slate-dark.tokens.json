        "h2": {
          "$value": "#70b8ff",
          "$type": "color"
        },
        "h3": {
          "$value": "#4ccce6",
          "$type": "color"
        },
        "h4": {
          "$value": "#ffca16",
          "$type": "color"
        },
        "h5": {
          "$value": "#baa7ff",
          "$type": "color"
        },
        "h6": {
          "$value": "#ff9592",
          "$type": "color"
        }
      },
      "body": {
        "primary": {
          "$value": "#edeef0",
          "$type": "color"
        },
        "secondary": {
          "$value": "#b0b4ba",
          "$type": "color"
        }
      },
      "link": {
        "default": {
          "$value": "#70b8ff",
