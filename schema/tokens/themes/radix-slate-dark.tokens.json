        "bg": {
          "$value": "#212225",
          "$type": "color"
        }
      },
      "codeBlock": {
        "fg": {
          "$value": "#edeef0",
          "$type": "color"
        },
        "bg": {
          "$value": "#212225",
          "$type": "color"
        }
      },
      "table": {
        "border": {
          "$value": "#43484e",
          "$type": "color"
        },
        "stripe": {
          "$value": "#18191b",
          "$type": "color"
