{
	"compilerOptions": {
		"target": "ES2020",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"lib": ["ES2020", "DOM"],
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"noEmit": true,
		"paths": {
			"@lgtm-hq/turbo-themes-core": ["./packages/core/src/index.ts"],
			"@lgtm-hq/turbo-themes-core/css/mappings": ["./packages/core/src/themes/css/mappings.ts"],
			"@lgtm-hq/turbo-themes-core/*": ["./packages/core/src/*"]
		}
	},
	"include": [
		"packages/core/src/**/*.ts",
		"packages/css/src/**/*.ts",
		"packages/theme-selector/src/**/*.ts"
	],
	"exclude": ["dist", "node_modules", "apps", "test"]
}
