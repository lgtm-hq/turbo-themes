---
/**
 * Home — Theme Showcase (ADR-0007).
 * Lean markup for the showcase redesign (epic #689, swap #683). Styles live
 * in assets/css/home.css; interactions in assets/js/homepage-showcase.ts,
 * which drives theming exclusively through the theme-selector integration
 * API and reads theme metadata from the data attributes rendered here.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { themeFullNames, themeIcons, validThemeIds } from '../data/theme-meta';

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const themeCount = validThemeIds.length;
const row1 = validThemeIds.slice(0, Math.ceil(validThemeIds.length / 2));
const row2 = validThemeIds.slice(Math.ceil(validThemeIds.length / 2));

const previewTabs = [
  { id: 'overview', label: 'Overview' },
  { id: 'components', label: 'Components' },
  { id: 'themes', label: 'Themes' },
] as const;

const features = [
  {
    title: 'CSS custom properties',
    desc: 'Ship tokens as a stylesheet. Restyle the UI without a runtime theme engine.',
  },
  {
    title: `${themeCount} curated themes`,
    desc: 'Light and dark packs from Catppuccin, Dracula, Nord, Gruvbox, and more.',
  },
  {
    title: 'Four platforms',
    desc: 'npm, RubyGems, PyPI, and Swift Package Manager — one token model everywhere.',
  },
  {
    title: 'Accessible by design',
    desc: 'WCAG AA contrast pairs for core text and surfaces, guarded by axe checks in CI.',
  },
];
---

<BaseLayout
  title="Home"
  description="Platform-agnostic design tokens and curated theme packs for web, Ruby, Python, and Swift"
  isHome={true}
>
  <link rel="stylesheet" href={`${baseUrl}/assets/css/home.css`} />

  <div class="showcase-page">
    <div id="showcase-spotlight" class="showcase-spotlight" aria-hidden="true">
      <div class="showcase-spotlight-left"></div>
      <div class="showcase-spotlight-right"></div>
    </div>

    <section class="showcase-hero" aria-labelledby="showcase-headline">
      <div class="showcase-hero-grid">
        <div class="showcase-hero-copy">
          <span class="showcase-badge showcase-reveal" style="--reveal-delay: 0.1s">Design tokens</span>

          <div class="showcase-headline-wrap showcase-reveal" style="--reveal-delay: 0.25s">
            <h1 id="showcase-headline" class="showcase-headline">
              <span id="showcase-text-mask" class="showcase-text-mask">
                <span class="showcase-text-mask-base">Curated themes</span>
                <span class="showcase-text-mask-reveal" aria-hidden="true">Curated themes</span>
              </span>
              <br />for every stack
            </h1>
          </div>

          <p class="showcase-lede showcase-reveal" style="--reveal-delay: 0.4s">
            Platform-agnostic design tokens spanning {themeCount} curated light and dark packs.
            Swap CSS custom properties—or the matching Ruby, Python, or Swift bindings—and keep one look everywhere.
          </p>

          <div class="showcase-cta showcase-reveal" style="--reveal-delay: 0.55s">
            <a href={`${baseUrl}/docs/`} class="btn btn-primary btn-lg" data-testid="home-cta-get-started">Get started</a>
            <a href={`${baseUrl}/themes/`} class="btn btn-outline btn-lg" data-testid="home-cta-explore-themes">
              Browse themes
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M5 12h14M12 5l7 7-7 7"></path>
              </svg>
            </a>
          </div>
        </div>

        <div class="showcase-hero-visual showcase-reveal" style="--reveal-delay: 0.35s">
          <div class="showcase-comet-wrap">
            <div id="showcase-comet-card" class="showcase-comet-card">
              <div id="showcase-comet-glare" class="showcase-comet-glare" aria-hidden="true"></div>
              <div class="showcase-preview">
                <div class="showcase-preview-bar">
                  <span></span><span></span><span></span>
                </div>
                <div class="showcase-preview-body">
                  <div class="showcase-preview-nav" role="tablist" aria-label="Preview sections">
                    {
                      previewTabs.map((tab, i) => (
                        <button
                          type="button"
                          class:list={['showcase-preview-tab', { active: i === 0 }]}
                          role="tab"
                          id={`showcase-tab-${tab.id}`}
                          aria-selected={i === 0 ? 'true' : 'false'}
                          aria-controls={`showcase-panel-${tab.id}`}
                          tabindex={i === 0 ? 0 : -1}
                          data-preview-tab={tab.id}
                          data-testid={`home-preview-tab-${tab.id}`}
                        >
                          {tab.label}
                        </button>
                      ))
                    }
                  </div>

                  <div class="showcase-preview-panels">
                    <div
                      class="showcase-preview-panel is-active"
                      id="showcase-panel-overview"
                      data-preview-panel="overview"
                      role="tabpanel"
                      aria-labelledby="showcase-tab-overview"
                    >
                      <div class="showcase-preview-stats">
                        <div class="showcase-preview-stat showcase-preview-stat-themes">
                          <span class="showcase-stat-glow" aria-hidden="true"></span>
                          <span class="label">Themes</span>
                          <strong>{themeCount}</strong>
                          <span class="showcase-stat-dots" aria-hidden="true">
                            <span></span><span></span><span></span><span></span>
                          </span>
                        </div>
                        <div class="showcase-preview-stat showcase-preview-stat-platforms">
                          <span class="showcase-stat-glow" aria-hidden="true"></span>
                          <span class="label">Platforms</span>
                          <strong>4</strong>
                          <span class="showcase-stat-chips">
                            <span>npm</span>
                            <span>Ruby</span>
                            <span>Python</span>
                            <span>Swift</span>
                          </span>
                        </div>
                      </div>

                      <div class="showcase-preview-specimens">
                        <div class="showcase-specimen">
                          <span class="showcase-specimen-label">Code</span>
                          <button
                            type="button"
                            class="showcase-code-block"
                            id="showcase-preview-code"
                            aria-label="Copy CSS example"
                            data-testid="home-preview-code-copy"
                          >
                            <code>
                              <span class="tok-prop">background</span>: <span class="tok-fn">var</span>(<span class="tok-var">--turbo-bg-surface</span>);
                              <br />
                              <span class="tok-prop">color</span>: <span class="tok-fn">var</span>(<span class="tok-var">--turbo-text-primary</span>);
                            </code>
                          </button>
                        </div>

                        <div class="showcase-specimen">
                          <span class="showcase-specimen-label">Typography</span>
                          <div class="showcase-type-sample">
                            <p class="showcase-type-h1">Heading One</p>
                            <p class="showcase-type-h2">Heading Two</p>
                            <p class="showcase-type-h3">Heading Three</p>
                          </div>
                        </div>
                      </div>

                      <div class="showcase-preview-progress">
                        <div class="showcase-preview-progress-head">
                          <span>Design coverage</span>
                          <strong id="showcase-progress-value">0%</strong>
                        </div>
                        <div
                          class="showcase-preview-progress-track"
                          role="progressbar"
                          aria-label="Design coverage"
                          aria-valuemin="0"
                          aria-valuemax="100"
                          aria-valuenow="0"
                          id="showcase-progress-bar"
                        >
                          <div id="showcase-progress-fill" class="showcase-preview-progress-fill"></div>
                        </div>
                      </div>
                    </div>

                    <div
                      class="showcase-preview-panel"
                      id="showcase-panel-components"
                      data-preview-panel="components"
                      role="tabpanel"
                      aria-labelledby="showcase-tab-components"
                      hidden
                    >
                      <label class="showcase-preview-field">
                        <span>Email</span>
                        <input type="email" class="showcase-preview-input" placeholder="you@example.com" />
                      </label>
                      <div class="showcase-preview-badges">
                        <span class="showcase-badge-pill success">Success</span>
                        <span class="showcase-badge-pill warning">Warning</span>
                        <span class="showcase-badge-pill danger">Danger</span>
                      </div>
                      <div class="btn-group">
                        <button type="button" class="btn btn-primary btn-sm" id="showcase-preview-primary" data-testid="home-preview-primary">Primary</button>
                        <button type="button" class="btn btn-outline btn-sm" id="showcase-preview-outline" data-testid="home-preview-outline">Outline</button>
                      </div>
                    </div>

                    <div
                      class="showcase-preview-panel"
                      id="showcase-panel-themes"
                      data-preview-panel="themes"
                      role="tabpanel"
                      aria-labelledby="showcase-tab-themes"
                      hidden
                    >
                      <div class="showcase-preview-theme">
                        <img
                          id="showcase-preview-theme-icon"
                          src={`${baseUrl}/assets/img/${themeIcons['catppuccin-mocha']}`}
                          alt=""
                          width="40"
                          height="40"
                        />
                        <div>
                          <span class="label">Active theme</span>
                          <strong id="showcase-preview-theme-name">{themeFullNames['catppuccin-mocha']}</strong>
                        </div>
                      </div>
                      <p class="showcase-preview-hint">Choose a pack from the carousel below — the theme selector restyles the whole page.</p>
                      <div class="showcase-preview-palette">
                        <span class="dot" style="background: var(--turbo-brand-primary)"></span>
                        <span class="dot" style="background: var(--turbo-state-info)"></span>
                        <span class="dot" style="background: var(--turbo-state-success)"></span>
                        <span class="dot" style="background: var(--turbo-state-warning)"></span>
                        <span class="dot" style="background: var(--turbo-state-danger)"></span>
                      </div>
                    </div>
                  </div>

                  <p id="showcase-preview-toast" class="showcase-preview-toast" aria-live="polite" hidden></p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="showcase-marquees" aria-label="Theme carousel">
      <div class="showcase-marquee-track">
        {
          [row1, row2].map((row, rowIndex) => (
            <div class:list={['showcase-marquee-row', rowIndex === 0 ? 'showcase-marquee-left' : 'showcase-marquee-right']}>
              {row.map((id) => (
                <button
                  type="button"
                  class="showcase-marquee-card"
                  data-theme-preview={id}
                  data-theme-name={themeFullNames[id] || id}
                  data-theme-icon={themeIcons[id]}
                  data-testid={`home-marquee-theme-${id}`}
                  title={themeFullNames[id] || id}
                  aria-label={`Apply ${themeFullNames[id] || id} theme`}
                  aria-pressed="false"
                >
                  <div class="showcase-marquee-swatch">
                    <img class="showcase-marquee-icon" src={`${baseUrl}/assets/img/${themeIcons[id]}`} alt="" width="32" height="32" />
                    <div class="showcase-marquee-dots">
                      <span class="dot" style="background: var(--turbo-brand-primary)"></span>
                      <span class="dot" style={`background: var(${rowIndex === 0 ? '--turbo-state-success' : '--turbo-state-info'})`}></span>
                      <span class="dot" style={`background: var(${rowIndex === 0 ? '--turbo-state-danger' : '--turbo-state-warning'})`}></span>
                    </div>
                  </div>
                  <span class="showcase-marquee-name">{themeFullNames[id] || id}</span>
                </button>
              ))}
            </div>
          ))
        }
      </div>

      <p class="showcase-marquee-footer">
        <a href={`${baseUrl}/themes/`} class="showcase-theme-more" data-testid="home-cta-view-all-themes">View all {themeCount} themes</a>
      </p>
    </section>

    <section class="showcase-features" aria-labelledby="showcase-features-title">
      <h2 id="showcase-features-title" class="visually-hidden">Why Turbo Themes</h2>
      <div class="showcase-features-grid">
        {
          features.map((f, i) => (
            <article class="showcase-feature" data-showcase-reveal style={`--reveal-delay: ${i * 0.08}s`}>
              <h3>{f.title}</h3>
              <p>{f.desc}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="showcase-footer-cta" data-showcase-reveal>
      <code>npm install @lgtm-hq/turbo-themes</code>
      <a href={`${baseUrl}/docs/`} class="btn btn-primary btn-lg" data-testid="home-cta-start-building">Read the docs</a>
    </section>
  </div>

  <script is:inline defer src={`${baseUrl}/assets/js/homepage-showcase.min.js`}></script>
</BaseLayout>
