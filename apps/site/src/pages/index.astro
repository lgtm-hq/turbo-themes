---
/**
 * Home — Noir Editorial (Design #2).
 * Source: landing-designs.html .d2 panel via issue #513.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { flavors } from '../../../../src/themes/registry.js';
import {
  themeNames,
  themeIcons,
  themeGroups,
  themeAppearances,
} from '../data/theme-meta';
const themeCount = flavors.length;
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');

/** Prefer iconic dark variants when a vendor has several flavors. */
const HERO_SWATCH_PREFERENCE: Record<string, string> = {
  catppuccin: 'catppuccin-mocha',
  dracula: 'dracula',
  gruvbox: 'gruvbox-dark',
  github: 'github-dark',
  bulma: 'bulma-dark',
  nord: 'nord',
  solarized: 'solarized-dark',
  'rose-pine': 'rose-pine',
  'tokyo-night': 'tokyo-night-dark',
};

const flavorById = Object.fromEntries(flavors.map((f) => [f.id, f]));

const heroSwatches = themeGroups.map((group) => {
  const preferred = HERO_SWATCH_PREFERENCE[group.id];
  const id =
    (preferred && group.flavors.includes(preferred) ? preferred : undefined) ??
    group.flavors.find((fid) => themeAppearances[fid] === 'dark') ??
    group.flavors[0];
  const flavor = flavorById[id];
  const short = themeNames[id] || flavor?.label || id;
  const name =
    short === group.displayName || group.displayName.includes(short)
      ? group.displayName
      : `${group.displayName} ${short}`;
  const color = flavor?.tokens.brand.primary ?? '#cba6f7';
  const colorEnd =
    flavor?.tokens.state.info ?? flavor?.tokens.background.surface ?? color;
  return { id, name, color, colorEnd };
});

const features: Array<{
  num: string;
  title: string;
  body: string;
  code?: string;
}> = [
  {
    num: '01',
    title: 'Pure CSS Variables',
    body: 'No runtime. No JavaScript. No build step required. Just CSS custom properties that work everywhere — reference any token with',
    code: 'var(--turbo-*)',
  },
  {
    num: '02',
    title: 'Platform Agnostic',
    body: 'npm, Python, Ruby, Swift. One token system, every platform. Ship consistent design across your entire stack.',
  },
  {
    num: '03',
    title: 'Framework Adapters',
    body: 'First-class adapters for Tailwind, Bulma, and Bootstrap. Drop in and your existing classes inherit theme colors instantly.',
  },
  {
    num: '04',
    title: 'WCAG Accessible',
    body: 'Every theme is tested for contrast compliance. Keyboard and screen reader support baked into the component layer.',
  },
];

const installMethods = [
  { label: 'npm', code: 'npm install turbo-themes' },
  { label: 'CDN', code: 'unpkg.com/turbo-themes/css/turbo-core.css' },
  { label: 'Python', code: 'pip install turbo-themes' },
  { label: 'Ruby', code: 'gem "turbo-themes"' },
] as const;
---

<BaseLayout title="Home" isHome={true}>
  <link rel="stylesheet" href={`${baseUrl}/assets/css/home.css`} />
  <section class="home-hero" aria-label="Hero">
    <div class="home-hero-copy">
      <p class="eyebrow">Design Tokens</p>
      <h1 class="home-hero-title">Themes that <em>speak</em></h1>
      <p class="home-hero-desc">
        {themeCount} curated color systems, meticulously crafted as platform-agnostic
        design tokens. Pure CSS. Zero dependencies. One import away.
      </p>
      <div class="home-hero-actions">
        <a href={`${baseUrl}/docs/`} class="btn-editorial">
          Get Started
          <span class="btn-arrow" aria-hidden="true">→</span>
        </a>
        <a href={`${baseUrl}/themes/`} class="btn-editorial btn-editorial-ghost">
          Browse Themes
        </a>
      </div>
    </div>

    <div class="home-hero-panel">
      <div class="home-swatch-grid" role="list" aria-label="Theme previews">
        {
          heroSwatches.map((swatch) => (
            <button
              type="button"
              class="home-swatch"
              role="listitem"
              data-theme-preview={swatch.id}
              data-name={swatch.name}
              title={swatch.name}
              aria-label={`Preview ${swatch.name} theme`}
              style={`--swatch-a: ${swatch.color}; --swatch-b: ${swatch.colorEnd};`}
            ></button>
          ))
        }
      </div>
      <p class="home-theme-count" aria-label={`${themeCount} themes`}>
        <span class="home-theme-count-num">{themeCount}</span>
        <sup class="home-theme-count-label">Themes</sup>
      </p>
    </div>
  </section>

  <section class="home-split" aria-labelledby="why-turbo-heading">
    <div class="home-split-label">
      <h2 id="why-turbo-heading" class="home-split-heading">Why Turbo?</h2>
    </div>
    <div class="home-split-body">
      <ul class="home-feature-list">
        {
          features.map((feature) => (
            <li class="home-feature-row">
              <span class="home-feature-num" aria-hidden="true">
                {feature.num}
              </span>
              <div class="home-feature-content">
                <h3 class="home-feature-title">{feature.title}</h3>
                <p class="home-feature-body">
                  {feature.body}
                  {feature.code ? (
                    <>
                      {' '}
                      <code>{feature.code}</code>.
                    </>
                  ) : null}
                </p>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="home-split" aria-labelledby="install-heading">
    <div class="home-split-label">
      <h2 id="install-heading" class="home-split-heading">Install</h2>
    </div>
    <div class="home-split-body">
      <ul class="home-install-list">
        {
          installMethods.map((method) => (
            <li class="home-install-row">
              <span class="home-install-label">{method.label}</span>
              <button
                type="button"
                class="home-install-code"
                data-copy={method.code}
                title="Click to copy"
              >
                <code>{method.code}</code>
              </button>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="home-cta" aria-labelledby="cta-heading">
    <h2 id="cta-heading" class="home-cta-title">
      Start building with <em>intention</em>
    </h2>
    <p class="home-cta-desc">Beautiful, accessible themes — ready in seconds.</p>
    <div class="home-cta-actions">
      <a href={`${baseUrl}/docs/`} class="btn-editorial">
        Read Documentation
        <span class="btn-arrow" aria-hidden="true">→</span>
      </a>
      <a
        href="https://github.com/lgtm-hq/turbo-themes"
        class="btn-editorial btn-editorial-ghost"
        target="_blank"
        rel="noopener noreferrer"
      >
        View on GitHub
      </a>
    </div>
  </section>

  <script is:inline define:vars={{ themeNames, themeIcons }}>
    (function () {
      function applyTheme(theme, activeEl) {
        var themeLink = document.getElementById('turbo-theme-css');
        var baseUrl = document.documentElement.getAttribute('data-baseurl') || '';

        document.documentElement.setAttribute('data-theme', theme);
        localStorage.setItem('turbo-theme', theme);

        if (themeLink) {
          themeLink.href = baseUrl + '/assets/css/themes/turbo/' + theme + '.css';
        }

        var themeLabel = document.getElementById('theme-label');
        var themeTriggerIcon = document.getElementById('theme-trigger-icon');
        if (themeLabel) {
          themeLabel.textContent = themeNames[theme] || theme;
        }
        if (themeTriggerIcon) {
          themeTriggerIcon.src =
            baseUrl + '/assets/img/' + (themeIcons[theme] || 'catppuccin-logo-macchiato.png');
        }

        document.querySelectorAll('.home-swatch[data-theme-preview]').forEach(function (b) {
          b.classList.toggle('active', b === activeEl);
        });

        document.querySelectorAll('.theme-menu .theme-option').forEach(function (opt) {
          opt.classList.toggle('active', opt.getAttribute('data-theme') === theme);
        });
      }

      document.querySelectorAll('.home-swatch[data-theme-preview]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var theme = btn.getAttribute('data-theme-preview');
          if (theme) applyTheme(theme, btn);
        });

        var currentTheme = document.documentElement.getAttribute('data-theme');
        if (btn.getAttribute('data-theme-preview') === currentTheme) {
          btn.classList.add('active');
        }
      });

      document.querySelectorAll('.home-install-code[data-copy]').forEach(function (el) {
        el.addEventListener('click', function () {
          var text = el.getAttribute('data-copy') || '';
          if (!text || !navigator.clipboard) return;
          navigator.clipboard.writeText(text).then(function () {
            el.classList.add('copied');
            setTimeout(function () {
              el.classList.remove('copied');
            }, 1500);
          }).catch(function () {
            console.warn('Failed to copy to clipboard');
          });
        });
      });
    })();
  </script>
</BaseLayout>
